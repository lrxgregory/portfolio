{% extends '/admin/admin.html.twig' %}

{% block title %}Administration du portfolio{% endblock %}

{% block body %}
<div class="container">
    <h1 class="text-center my-5">Administration du portfolio</h1>
    <div class="row">
        <div class="col">
            <div class="card text-white bg-secondary mr-5" style="width: 100%;">
                <div class="card-header h4">Ajout de compétences</div>
                <div class="card-body">
                    {{form_start(form)}}
                    {{form_widget(form)}}
                    <button type="submit" class="btn btn-info mt-3">Ajouter une compétence</button>
                    {{form_end(form)}}
                </div>
            </div>
        </div>
        
        <div class="col">
            <div class="card text-white bg-secondary ml-5" style="width: 100%;">
                <div class="card-header h4">Ajout de projets</div>
                <div class="card-body">
                    {{form_start(workform)}}
                    {{form_widget(workform)}}
                    <button type="submit" class="btn btn-info mt-3">Ajouter une compétence</button>
                    {{form_end(workform)}}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
